\"selectiveLogic\":0},{\"name\":\"\",\"keys\":[\"Classroom\"],\"secondary_keys\":[],\"content\":\"Room: The Classroom - where lessons are taught on topics ranging from wilderness survival to algebra. Kids scratch with pencils as a teen at a chalkboard explains survival skills\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":14,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"position\":0,\"probability\":100,\"displayIndex\":1,\"display_index\":13,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":true,\"exclude_recursion\":false,\"linked\":false,\"embedded\":true},\"probability\":100,\"selectiveLogic\":0},{\"name\":\"\",\"keys\":[\"Dance Hall\"],\"secondary_keys\":[],\"content\":\"Room: The Dance Hall - filled with music and instruments, it's where the kids can let loose and dance their cares away. Music pulses, bodies sway and stomp to a beat in the dim light.\\n\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":15,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"position\":0,\"probability\":100,\"displayIndex\":1,\"display_index\":14,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":true,\"exclude_recursion\":false,\"linked\":false,\"embedded\":true},\"probability\":100,\"selectiveLogic\":0},{\"name\":\"\",\"keys\":[\"Game Room\"],\"secondary_keys\":[],\"content\":\"Room: The Game Room - stocked with board games, cards, and other simple activities to pass the time. Dice rattle and cards slap onto tables amid shouts of victory and defeat.\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":16,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"