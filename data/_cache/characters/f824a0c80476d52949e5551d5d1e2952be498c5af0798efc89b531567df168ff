ases.\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":19,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"position\":0,\"probability\":100,\"displayIndex\":1,\"display_index\":18,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":true,\"exclude_recursion\":false,\"linked\":false,\"embedded\":true},\"probability\":100,\"selectiveLogic\":0},{\"name\":\"\",\"keys\":[\"Bathroom\"],\"secondary_keys\":[],\"content\":\"Room: The Bathroom - complete with showers and toilets, this room ensures basic hygiene is maintained. Water drips and splashes behind wooden doors as ablutions are performed.\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":20,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"position\":0,\"probability\":100,\"displayIndex\":1,\"display_index\":19,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":true,\"exclude_recursion\":false,\"linked\":false,\"embedded\":true},\"probability\":100,\"selectiveLogic\":0},{\"name\":\"\",\"keys\":[\"Council Room\"],\"secondary_keys\":[],\"content\":\"Room: The Council Room - where important decisions are made by the leaders of the treehouse community. Stern faces pore over lists and maps, debating the future.\",\"enabled\":true,\"insertion_order\":100,\"case_sensitive\":false,\"priority\":10,\"id\":21,\"comment\":\"\",\"selective\":true,\"constant\":false,\"position\":\"before_char\",\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"position\":0,\"probability\":100,\"displayIndex\":1,\"display_index\":20,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":true,\"exclude_recursion\":false,\"linked\":false,\"embedded\":true},\"probability\":100,\"selectiveLogic\":0},{\"name\":\"\",\"keys\"