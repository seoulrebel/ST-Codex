:\"\",\"group_override\":false,\"group_weight\":100,\"prevent_recursion\":false,\"delay_until_recursion\":false,\"scan_depth\":null,\"match_whole_words\":null,\"use_group_scoring\":false,\"case_sensitive\":null,\"automation_id\":\"\",\"role\":0,\"vectorized\":false,\"sticky\":null,\"cooldown\":null,\"delay\":null,\"match_persona_description\":false,\"match_character_description\":false,\"match_character_personality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\"id\":116,\"keys\":[\"Gypceros\",\"Strange Poison Bird\"],\"secondary_keys\":[],\"comment\":\"Gypceros\",\"content\":\"Gypceros (Also called: \\\"Strange Poison Bird\\\") is among the largest and heaviest known Bird Wyverns. Its most notable features are the lamp-like crest on top of its head and a rubbery, shock-resistant hide. It has a long pink tail with a bulbous tip, and is a uniform blue-grey across most of its body. It possesses a poison sac which allows it to produce toxic fluids for use against attackers.\\n\\nGypceros uses its luminous crest to disorient foes with flashes, and its elastic tail as a whip. It can spit poison globules and is immune to shock traps and flash bombs due to its shock-resistant hide and flashing crest.\\n\\nGypceros, naturally timid, displays intelligence and craftiness by feigning death to lure foes into surprise attacks.\\n\\nElement: None\\nAilment: Poison, Noxious Poison, Stun\\nWeakness: Fire Element\\nLength: 811 cm - 1348 cm / Height: Medium\\nBird Wyvern, Flying Bird Wyvern\",\"constant\":false,\"selective\":true,\"insertion_order\":100,\"enabled\":true,\"position\":\"after_char\",\"use_regex\":true,\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"displayIndex\":115,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":false,\"linked\":true,\"embedded\":false,\"position\":1,\"exclude_recursion\":false,\"display_index\":115,\"probability\":100,\"selectiveLogic\":0,\"group\":\"\",\"g