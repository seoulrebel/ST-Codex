,\"prevent_recursion\":false,\"delay_until_recursion\":false,\"scan_depth\":null,\"match_whole_words\":null,\"use_group_scoring\":false,\"case_sensitive\":null,\"automation_id\":\"\",\"role\":0,\"vectorized\":false,\"sticky\":null,\"cooldown\":null,\"delay\":null,\"match_persona_description\":false,\"match_character_description\":false,\"match_character_personality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\"id\":370,\"keys\":[\"Bow\"],\"secondary_keys\":[],\"comment\":\"Bow\",\"content\":\"The Bow (~ 200 cm tall)  is a versatile ranged weapon known for its agility and quick firing capabilities. It is relatively lightweight and allows hunters to maintain mobility during combat. The bow's design emphasizes precision and agility, making it ideal for hunters who prefer a hit-and-run playstyle. With the ability to charge shots and unleash various coatings, the Bow excels in delivering consistent damage while providing flexibility in engaging monsters from a distance.\",\"constant\":false,\"selective\":true,\"insertion_order\":100,\"enabled\":true,\"position\":\"after_char\",\"use_regex\":true,\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"displayIndex\":369,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":false,\"linked\":true,\"embedded\":false,\"position\":1,\"exclude_recursion\":false,\"display_index\":369,\"probability\":100,\"selectiveLogic\":0,\"group\":\"\",\"group_override\":false,\"group_weight\":100,\"prevent_recursion\":false,\"delay_until_recursion\":false,\"scan_depth\":null,\"match_whole_words\":null,\"use_group_scoring\":false,\"case_sensitive\":null,\"automation_id\":\"\",\"role\":0,\"vectorized\":false,\"sticky\":null,\"cooldown\":null,\"delay\":null,\"match_persona_description\":false,\"match_character_description\":false,\"match_character_personality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\