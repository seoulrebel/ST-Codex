ality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\"id\":358,\"keys\":[\"Longsword\",\"LS\"],\"secondary_keys\":[],\"comment\":\"Longsword\",\"content\":\"The Longsword, or \\\"LS\\\" (~ 200 cm long) is a versatile, two-handed weapon known for its fluid and elegant slashing motions. It offers a good balance between reach and agility, allowing hunters to execute swift combos. The weapon is lightweight, providing mobility in combat, and hunters can build up spirit levels for powerful, spirit-infused attacks. Mastering the Longsword requires understanding its intricate spirit gauge mechanics.\",\"constant\":false,\"selective\":true,\"insertion_order\":100,\"enabled\":true,\"position\":\"after_char\",\"use_regex\":true,\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"displayIndex\":357,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":false,\"linked\":true,\"embedded\":false,\"position\":1,\"exclude_recursion\":false,\"display_index\":357,\"probability\":100,\"selectiveLogic\":0,\"group\":\"\",\"group_override\":false,\"group_weight\":100,\"prevent_recursion\":false,\"delay_until_recursion\":false,\"scan_depth\":null,\"match_whole_words\":null,\"use_group_scoring\":false,\"case_sensitive\":null,\"automation_id\":\"\",\"role\":0,\"vectorized\":false,\"sticky\":null,\"cooldown\":null,\"delay\":null,\"match_persona_description\":false,\"match_character_description\":false,\"match_character_personality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\"id\":359,\"keys\":[\"SnS\",\"Sword and Shield\"],\"secondary_keys\":[],\"comment\":\"Sword and Shield\",\"content\":\"The Sword and Shield, or \\\"SnS\\\" (Sword ~ 100 cm and Shield ~ 80 cm in diameter) is a nimble, one-handed weapon combo that offers a quick and versatile playstyle. It is relatively lightweight, allowing hunters to maintain agility and easily switch between offense and defense. While individual attacks may be less powerful, the ability to use items without sheathing the weapon adds tactical advantages. The Sword and Shield is an excellent choice for hunters who prefer a fast-paced, adaptable combat approach.\",\"constant\":false,\"selective\":true,\"insertion_order\":100,\"enabled\":true,\"position\":\"after_char\",\"use_regex\":true,\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"displayIndex\":358,\"useProbability\":true,\"characterFilter\":null,\"excludeRecursion\":false,\"linked\":true,\"embedded\":false,\"position\":1,\"exclude_recursion\":false,\"display_index\":358,\"probability\":100,\"selectiveLogic\":0,\"group\":\"\",\"group_override\":false,\"group_weight\":100,\"prevent_recursion\":false,\"delay_until_recursion\":false,\"scan_depth\":null,\"match_whole_words\":null,\"use_group_scoring\":false,\"case_sensitive\":null,\"automation_id\":\"\",\"role\":0,\"vectorized\":false,\"sticky\":null,\"cooldown\":null,\"delay\":null,\"match_persona_description\":false,\"match_character_description\":false,\"match_character_personality\":false,\"match_character_depth_prompt\":false,\"match_scenario\":false,\"match_creator_notes\":false}},{\"id\":360,\"keys\":[\"Dual Blades\",\"DB\"],\"secondary_keys\":[],\"comment\":\"Dual Blades\",\"content\":\"The Dual Blades or, \\\"DB\\\" (both ~ 100 - 150 cm in length) are a pair of fast and agile weapons, each resembling short swords. They are relatively lightweight, emphasizing rapid attacks and mobility. Dual Blades hunters can unleash a flurry of strikes, allowing for high damage output. Despite individual hits being less powerful, the speed and combo potential make the Dual Blades a dynamic choice for aggressive playstyles.\",\"constant\":false,\"selective\":true,\"insertion_order\":100,\"enabled\":true,\"position\":\"after_char\",\"use_regex\":true,\"extensions\":{\"depth\":4,\"weight\":10,\"addMemo\":true,\"displayIndex\":359,\"useProbability\":true,\"characterFilter\"